# Local development overrides — copy this file to values.local.yaml and adjust as needed.
# values.local.yaml is gitignored; this example file is the committed reference.
#
# Usage:
#   1. Create the secret out-of-band (do NOT put it in values.local.yaml):
#
#        kubectl create secret generic lfx-v2-forwards-service \
#          --namespace lfx \
#          --from-literal=forwardemail-api-token=YOUR_TOKEN_HERE
#
#      The default values.yaml already references this secret via valueFrom,
#      so the deployment will pick it up automatically. This chart does not
#      generate the secret for you in local dev (ESO is disabled by default).
#
#   2. Copy and edit overrides:
#        cp values.local.yaml.example values.local.yaml
#
#   3. Install:
#        helm upgrade --install ... -f values.yaml -f values.local.yaml

image:
  repository: ghcr.io/linuxfoundation/lfx-v2-forwards-service/forwards-api
  tag: "latest"
  pullPolicy: Never

replicaCount: 1

app:
  # Only override env keys whose defaults you need to change for local dev.
  # All other keys inherit from values.yaml.
  environment:
    LOG_LEVEL:
      value: "debug"
    AUTH0_DOMAIN:
      value: "your-dev-tenant.auth0.com"
    AUTH0_AUDIENCE:
      value: "https://your-dev-tenant.auth0.com/api/v2/"
    # FORWARDEMAIL_API_TOKEN is already a valueFrom secretKeyRef in values.yaml.
    # If your local secret has a different name/key, override here, e.g.:
    # FORWARDEMAIL_API_TOKEN:
    #   valueFrom:
    #     secretKeyRef:
    #       name: my-local-secret
    #       key: token

  otel:
    serviceName: ""
    protocol: "grpc"
    endpoint: ""
    insecure: "false"
    tracesExporter: "none"
    tracesSampler: ""
    tracesSamplerArg: ""
    metricsExporter: "none"
    logsExporter: "none"
    propagators: "tracecontext,baggage,jaeger"

nats:
  credentialsFile: ""
